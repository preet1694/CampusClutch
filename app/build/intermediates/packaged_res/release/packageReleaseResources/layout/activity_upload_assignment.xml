<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center"
    android:background="@android:color/white">

    <!-- Assignment Title Input -->
    <EditText
        android:id="@+id/etAssignmentTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Assignment Title"
        android:inputType="text"
        android:padding="10dp"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <!-- Assignment Description Input -->
    <EditText
        android:id="@+id/etAssignmentDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Assignment Description"
        android:inputType="textMultiLine"
        android:minLines="3"
        android:padding="10dp"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"/>

    <!-- Selected File Name Display -->
    <TextView
        android:id="@+id/tvAssignmentFileName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No file selected"
        android:textSize="16sp"
        android:textStyle="italic"
        android:gravity="center"
        android:layout_marginBottom="16dp"/>

    <!-- Button to Select Assignment File -->
    <Button
        android:id="@+id/btnSelectAssignmentFile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Select Assignment File"
        android:padding="10dp"
        android:layout_marginBottom="16dp"
        android:textSize="18sp"
        android:background="@android:color/holo_blue_light"
        android:textColor="@android:color/white"/>

    <!-- Button to Upload the Assignment -->
    <Button
        android:id="@+id/btnUploadAssignment"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Upload Assignment"
        android:padding="10dp"
        android:textSize="18sp"
        android:background="@android:color/holo_green_light"
        android:textColor="@android:color/white"/>

</LinearLayout>
